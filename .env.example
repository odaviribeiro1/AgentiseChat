# ============================================================================
# Agentise Chat — Boilerplate open source self-hosted
# ============================================================================
#
# Copie este arquivo para .env.local e preencha com os valores reais para
# desenvolvimento local. Para produção, configure cada variável no painel
# correspondente (instruções abaixo). Veja README.md para o passo a passo
# completo de setup.
#
# ATENÇÃO: jamais commite .env.local — está no .gitignore.
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# GRUPO A — Frontend (Vercel → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────
# Variáveis NEXT_PUBLIC_* são embutidas no bundle do navegador no build.
# Após adicioná-las na Vercel, é obrigatório redeployar.

# URL pública do seu projeto Supabase
# Onde obter: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Chave anônima do Supabase (segura para expor — RLS protege os dados)
# Onde obter: Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL pública do app (usada para montar redirect_uri OAuth e disparar crons)
# Em produção: domínio da Vercel (ex: https://meu-projeto.vercel.app)
# Em dev local: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Alias opcional — se definida, usada como fallback do APP_URL (legado)
# NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# GRUPO B — Server-only / Vercel Environment Variables (NUNCA expor no bundle)
# ─────────────────────────────────────────────────────────────────────────────
# Configure cada uma em: Vercel → Settings → Environment Variables.
# Ao colar via CLI ou painel, marque os 3 ambientes (Production / Preview /
# Development) conforme o seu fluxo. Não use prefixo NEXT_PUBLIC_ aqui.

# Service Role Key do Supabase — bypassa RLS, usada por webhooks e crons
# Onde obter: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# OpenAI API key (usada pelo step de IA das automações)
# Onde obter: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Meta / Instagram OAuth e Webhook ────────────────────────────────────────
# Crie um app em https://developers.facebook.com/apps com produto
# "Facebook Login for Business" + "Webhooks" + "Instagram Graph API".
META_APP_ID=
META_APP_SECRET=

# Token aleatório para verificação do webhook (você inventa)
# Sugestão: openssl rand -hex 24
META_VERIFY_TOKEN=

# URL pública do callback OAuth — deve estar autorizada no painel da Meta
META_REDIRECT_URI=https://your-app.vercel.app/api/auth/meta/callback

# URL pública do webhook — informada no painel da Meta ao assinar comments/messages
META_WEBHOOK_URL=https://your-app.vercel.app/api/webhook/instagram

# Opcional: ID da configuração do Facebook Login for Business
# Use somente se estiver usando configurações pré-aprovadas pela Meta.
META_CONFIG_ID=

# Opcional: Instagram Token (IGAA) global usado como fallback em sendPrivateReply
# Em produção, prefira armazenar o token por conta no banco (accounts.ig_access_token).
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_DM_TOKEN=

# Chave de criptografia AES-256-GCM dos tokens armazenados no banco
# Tem que ter EXATAMENTE 64 caracteres hexadecimais (32 bytes).
# Gere com: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Segredo para autenticar chamadas dos cron jobs (header Authorization: Bearer ...)
# Vercel Cron envia este header automaticamente quando configurado em vercel.json.
# Gere com: openssl rand -hex 32
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# GRUPO C — GitHub Actions (CI / migrations) — opcional
# ─────────────────────────────────────────────────────────────────────────────
# Necessárias apenas se você quiser que o GitHub Actions aplique migrations
# Supabase automaticamente via CLI. Configure em:
#   GitHub repo → Settings → Secrets and variables → Actions → New repository secret

# Personal Access Token do Supabase
# Onde obter: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...

# Project Reference do seu projeto Supabase
# Onde obter: Supabase Dashboard → Project Settings → General → Reference ID
# SUPABASE_PROJECT_REF=
