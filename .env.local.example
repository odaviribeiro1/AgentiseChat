# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...     # NUNCA expor no frontend

# ─── Meta / Instagram ────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=                          # NUNCA expor no frontend
META_VERIFY_TOKEN=                        # Token aleatório para verificação do webhook
META_REDIRECT_URI=https://seuapp.vercel.app/api/auth/meta/callback
META_CONFIG_ID=                           # Opcional: config ID do Facebook Login for Business

# ─── Tokens ──────────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=                     # 64 hex chars — gerar com: openssl rand -hex 32

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                     # NUNCA expor no frontend

# ─── Cron / QStash ───────────────────────────────────────────────────────────
CRON_SECRET=                              # Segredo para autenticar cron jobs do QStash

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://seuapp.vercel.app
